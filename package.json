{
  "name": "nexus-cli",
  "version": "0.1.0",
  "description": "Unofficial CLI for non-premium Nexus users.",
  "type": "module",
  "bin": {
    "nexus": "./dist/cli/index.js"
  },
  "main": "./dist/cli/index.js",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "vite build",
    "build:binaries": "bash scripts/build-binaries.sh",
    "dev": "vite build --watch",
    "start": "node ./dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live": "NEXUS_LIVE_TESTS=1 vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,html}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "camoufox-js": "^0.11.1",
    "ora": "^9.4.1",
    "playwright-core": "1.49.1",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@types/yargs": "^17.0.33",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.1",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.62.0",
    "vite": "^5.4.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^2.1.0"
  },
  "overrides": {
    "playwright-core": "1.49.1"
  }
}
